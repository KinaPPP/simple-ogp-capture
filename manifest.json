{
  "manifest_version": 3,
  "name": "シンプルOGPキャプチャ",
  "version": "1.1.3",
  "description": "現在のタブをOGP推奨サイズ（1200×630px）でキャプチャしてダウンロード",
  "author": "KINA",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "downloads",
    "offscreen",
    "storage",
    "windows"
  ],
  "action": {
    "default_title": "OGPキャプチャ（1200×630）",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
